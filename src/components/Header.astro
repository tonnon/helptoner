---
import Logo from './Logo.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
import { WHATSAPP_URL } from '../config';

const navLinks = [
  { href: '#servicos', label: 'Serviços' },
  { href: '#sobre', label: 'Sobre' },
  { href: '#localizacao', label: 'Localização' },
  { href: '#contato', label: 'Contato' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-slate-100 bg-white/90 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-20 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6"
  >
    <a
      href="#inicio"
      class="text-xl sm:text-2xl transition-opacity hover:opacity-80"
      aria-label="Helptoner — voltar ao início da página"
    >
      <Logo />
    </a>

    <nav aria-label="Navegação principal" class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium text-slate-600 transition-colors hover:text-brand-800"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-2 rounded-full bg-wa-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-wa-600 hover:shadow-md sm:inline-flex"
      >
        <WhatsAppIcon class="h-4 w-4" />
        Fale no WhatsApp
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-11 w-11 items-center justify-center rounded-xl text-brand-900 transition-colors hover:bg-brand-50 md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menu de navegação"
      >
        <svg
          id="icon-open"
          viewBox="0 0 24 24"
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        <svg
          id="icon-close"
          viewBox="0 0 24 24"
          class="hidden h-6 w-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menu mobile -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-100 bg-white px-4 pb-6 pt-2 shadow-lg md:hidden"
  >
    <nav aria-label="Navegação móvel" class="flex flex-col">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link rounded-lg px-3 py-3 text-base font-medium text-slate-700 transition-colors hover:bg-brand-50 hover:text-brand-800"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <a
      href={WHATSAPP_URL}
      target="_blank"
      rel="noopener"
      class="mt-3 flex items-center justify-center gap-2 rounded-full bg-wa-500 px-5 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-wa-600"
    >
      <WhatsAppIcon class="h-5 w-5" />
      Fale no WhatsApp
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  function setMenu(open: boolean) {
    menu.classList.toggle('hidden', !open);
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute(
      'aria-label',
      open ? 'Fechar menu de navegação' : 'Abrir menu de navegação'
    );
  }

  toggle.addEventListener('click', () => {
    setMenu(menu.classList.contains('hidden'));
  });

  // Fecha o menu ao tocar em um link âncora
  menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });

  // Sombra sutil no header ao rolar a página
  const header = document.querySelector('header')!;
  const onScroll = () => {
    header.classList.toggle('header-scrolled', window.scrollY > 12);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
