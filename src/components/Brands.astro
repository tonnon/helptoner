---
const brands = [
  'HP',
  'Epson',
  'Canon',
  'Brother',
  'Samsung',
  'Lexmark',
  'Kyocera',
  'Ricoh',
  'Xerox',
  'OKI',
];
---

<section aria-label="Marcas atendidas" class="bg-white pt-14 pb-4 sm:pt-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <p
      class="text-center text-xs font-semibold uppercase tracking-[0.25em] text-slate-400"
    >
      Especialistas nas principais marcas do mercado
    </p>
    <div
      class="marquee relative mt-7 overflow-hidden [mask-image:linear-gradient(90deg,transparent,black_12%,black_88%,transparent)]"
    >
      <div class="marquee-track flex w-max items-center">
        {
          [...brands, ...brands].map((brand) => (
            <span class="mx-7 flex items-center gap-7 whitespace-nowrap font-display text-2xl font-bold tracking-tight text-slate-300 transition-colors hover:text-brand-700 sm:mx-9 sm:gap-9">
              {brand}
              <span class="h-1.5 w-1.5 rounded-full bg-accent-500/40" aria-hidden="true" />
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
