---
import Logo from './Logo.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
import { BUSINESS, WHATSAPP_URL } from '../config';

const year = new Date().getFullYear();

const navLinks = [
  { href: '#servicos', label: 'Serviços' },
  { href: '#diferenciais', label: 'Diferenciais' },
  { href: '#sobre', label: 'Sobre' },
  { href: '#faq', label: 'Dúvidas frequentes' },
  { href: '#localizacao', label: 'Localização' },
  { href: '#contato', label: 'Contato' },
];
---

<footer class="bg-brand-950 pt-16 pb-8 text-slate-300">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <a href="#inicio" class="inline-flex items-center text-2xl leading-none" aria-label="Helptoner — voltar ao início">
          <Logo variant="dark" />
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-400">
          Conserto, manutenção e suprimentos para impressoras em Praia Grande e
          em todo o litoral sul de São Paulo. {BUSINESS.slogan}.
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-wa-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-wa-600"
        >
          <WhatsAppIcon class="h-4 w-4" />
          Fale no WhatsApp
        </a>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold uppercase tracking-widest text-white">
          Contato
        </h2>
        <address class="mt-5 space-y-3 text-sm not-italic leading-relaxed text-slate-400">
          <p>
            {BUSINESS.address.street}<br />
            {BUSINESS.address.neighborhood}, {BUSINESS.address.city} – {
              BUSINESS.address.state
            } · CEP {BUSINESS.address.zip}
          </p>
          <p>
            {
              BUSINESS.phones.map((phone, i) => (
                <>
                  <a
                    href={phone.href}
                    class="transition-colors hover:text-white"
                  >
                    {phone.display}
                  </a>
                  {i < BUSINESS.phones.length - 1 && <br />}
                </>
              ))
            }
          </p>
          <p>
            <strong class="font-medium text-slate-300">Horário:</strong><br />
            {BUSINESS.hours.display}<br />
            {BUSINESS.hours.displaySaturday}
          </p>
        </address>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold uppercase tracking-widest text-white">
          Navegação
        </h2>
        <nav aria-label="Links do rodapé" class="mt-5">
          <ul class="space-y-2.5 text-sm">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-slate-400 transition-colors hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col items-center justify-between gap-3 border-t border-white/10 pt-7 text-xs text-slate-500 sm:flex-row"
    >
      <p>© {year} {BUSINESS.name} — Todos os direitos reservados.</p>
      <p>
        Conserto de impressoras, toners e cartuchos em Praia Grande – SP.
      </p>
    </div>
  </div>
</footer>
