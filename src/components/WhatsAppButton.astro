---
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
import { WHATSAPP_URL } from '../config';
---

<a
  href={WHATSAPP_URL}
  target="_blank"
  rel="noopener"
  aria-label="Conversar com a Helptoner no WhatsApp"
  class="wa-pulse fixed bottom-5 right-5 z-50 flex h-15 w-15 items-center justify-center rounded-full bg-wa-500 text-white shadow-xl transition-transform hover:scale-110 hover:bg-wa-600 sm:bottom-7 sm:right-7"
>
  <WhatsAppIcon class="h-8 w-8" />
</a>
