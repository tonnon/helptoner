---
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
import { BUSINESS, WHATSAPP_URL } from '../config';
---

<section id="contato" class="bg-brand-50/60 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div
      class="reveal relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-brand-950 via-brand-900 to-brand-700 px-6 py-16 text-center shadow-2xl shadow-brand-900/25 sm:px-16 sm:py-24"
    >
      <div class="bg-dots absolute inset-0 opacity-70" aria-hidden="true"></div>
      <div
        class="pointer-events-none absolute -top-28 left-1/4 h-80 w-80 rounded-full bg-cyan-glow/15 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-32 right-0 h-80 w-80 rounded-full bg-accent-500/20 blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-2xl">
        <h2
          class="font-display text-3xl font-bold tracking-tight text-white sm:text-[2.8rem] sm:leading-tight"
        >
          Impressora parada?{' '}
          <span class="text-gradient-accent">A gente resolve agora.</span>
        </h2>
        <p
          class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-slate-300 sm:text-lg"
        >
          Mande uma mensagem contando o modelo e o problema. Nossa equipe em
          Praia Grande responde rápido com o próximo passo — sem compromisso.
        </p>

        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener"
          class="btn-shine mt-10 inline-flex items-center justify-center gap-3 rounded-full bg-wa-500 px-11 py-5 text-lg font-semibold text-white shadow-xl shadow-wa-500/25 transition-all hover:-translate-y-0.5 hover:bg-wa-600 hover:shadow-2xl hover:shadow-wa-500/35"
        >
          <WhatsAppIcon class="h-6 w-6" />
          Chamar no WhatsApp agora
        </a>

        <div
          class="mt-9 flex flex-wrap items-center justify-center gap-3 text-sm"
        >
          <span class="text-slate-400">Ou ligue:</span>
          {
            BUSINESS.phones.map((phone) => (
              <a
                href={phone.href}
                class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 font-medium text-slate-200 backdrop-blur-sm transition-colors hover:border-white/30 hover:text-white"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-3.5 w-3.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 4h4l1.5 4-2 1.5a12 12 0 0 0 6 6L16 13.5l4 1.5v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z" />
                </svg>
                {phone.display}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
