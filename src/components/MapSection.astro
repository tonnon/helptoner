---
import { BUSINESS, MAPS_EMBED_URL, MAPS_LINK_URL } from '../config';
---

<section id="localizacao" class="bg-brand-50/60 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p
        class="text-sm font-semibold uppercase tracking-widest text-accent-500"
      >
        Localização
      </p>
      <h2
        class="font-display mt-3 text-3xl font-bold text-brand-900 sm:text-4xl"
      >
        Visite nossa loja no Boqueirão
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        Estamos na avenida mais movimentada de Praia Grande, pertinho da praia
        do Boqueirão. Traga seu equipamento ou chame a gente no WhatsApp.
      </p>
    </div>

    <div
      class="reveal reveal-delay-1 mt-12 grid gap-6 overflow-hidden lg:grid-cols-[1fr_2fr]"
    >
      <address
        class="flex flex-col justify-center gap-6 rounded-3xl border border-brand-100 bg-white p-8 not-italic shadow-sm"
      >
        <div class="flex items-start gap-4">
          <span
            class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-700"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11z M12 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"
              ></path>
            </svg>
          </span>
          <div>
            <h3 class="font-display text-sm font-semibold text-brand-900">
              Endereço
            </h3>
            <p class="mt-1 text-sm leading-relaxed text-slate-600">
              {BUSINESS.address.street}<br />
              {BUSINESS.address.neighborhood}, {BUSINESS.address.city} – {
                BUSINESS.address.state
              }<br />
              CEP {BUSINESS.address.zip}
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <span
            class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-700"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 7v5l3 3 M21 12a9 9 0 1 1-9-9 9 9 0 0 1 9 9z"></path>
            </svg>
          </span>
          <div>
            <h3 class="font-display text-sm font-semibold text-brand-900">
              Horário de atendimento
            </h3>
            <p class="mt-1 text-sm leading-relaxed text-slate-600">
              {BUSINESS.hours.display}<br />
              {BUSINESS.hours.displaySaturday}
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <span
            class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-700"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M5 4h4l1.5 4-2 1.5a12 12 0 0 0 6 6L16 13.5l4 1.5v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"
              ></path>
            </svg>
          </span>
          <div>
            <h3 class="font-display text-sm font-semibold text-brand-900">
              Telefones
            </h3>
            <p class="mt-1 text-sm leading-relaxed text-slate-600">
              {
                BUSINESS.phones.map((phone, i) => (
                  <>
                    <a
                      href={phone.href}
                      class="transition-colors hover:text-brand-700"
                    >
                      {phone.display}
                    </a>
                    {i < BUSINESS.phones.length - 1 && <br />}
                  </>
                ))
              }
            </p>
          </div>
        </div>

        <a
          href={MAPS_LINK_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-brand-200 px-6 py-3 text-sm font-semibold text-brand-800 transition-colors hover:border-brand-400 hover:bg-brand-50"
        >
          Como chegar
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17L17 7M9 7h8v8"></path>
          </svg>
        </a>
      </address>

      <div
        class="overflow-hidden rounded-3xl border border-brand-100 shadow-sm"
      >
        <iframe
          src={MAPS_EMBED_URL}
          title={`Mapa com a localização da Helptoner: ${BUSINESS.address.full}`}
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          class="h-80 w-full border-0 sm:h-full sm:min-h-96"
        >
        </iframe>
      </div>
    </div>
  </div>
</section>
